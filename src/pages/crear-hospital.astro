    <title>Crear Hospital - Salud Digital</title>
  </head>
  <body class="bg-gray-50 min-h-screen py-12">
    <div class="container mx-auto px-4">
      
      <div class="mb-8 text-center">
        <h1 class="text-3xl font-bold text-blue-800">Panel de Administración</h1>
        <p class="text-gray-600 mt-2">Gestión de accesos y roles</p>
      </div>

      <RegisterHospital client:load client:only="react" />
      
      <div class="mt-8 text-center">
        <a href="/" class="text-blue-600 hover:underline">&larr; Volver al inicio</a>
      </div>

